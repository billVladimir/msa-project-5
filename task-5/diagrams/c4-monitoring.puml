@startuml c4-monitoring
!include <C4/C4_Container>

title C4 - Диаграмма контейнеров: Мониторинг, логирование и оповещение TradeWare

Person(devops, "DevOps / SRE", "Мониторинг здоровья системы,\nанализ метрик и логов,\nреагирование на оповещения")

System_Boundary(tradeware, "TradeWare Monitoring & ETL Platform") {

    Container(batch_app, "Spring Batch ETL App", "Spring Boot / Java 17 / Actuator / Micrometer", "ETL-пайплайн: обработка CSV, обогащение данными лояльности. Отдаёт метрики через /actuator/prometheus. Логи в JSON через stdout.")

    ContainerDb(postgres, "PostgreSQL", "PostgreSQL 15+", "products, loyality_data,\nBATCH_* метаданные")

    Container(prometheus, "Prometheus", "v3.4.0", "Сбор метрик по pull-модели\nкаждые 5 сек.\nОценка alerting rules.")

    Container(grafana, "Grafana", "v12.0.1", "Визуализация метрик:\nCPU, JVM Memory, Threads,\nBatch Job Duration,\nJDBC Pool, GC Pauses.\nОповещения по метрикам.")

    Container(filebeat, "Filebeat", "v7.17.28", "Сбор логов Docker-контейнеров\nиз stdout/stderr.\nПарсинг JSON-логов.")

    Container(logstash, "Logstash", "v7.17.28", "Приём логов от Filebeat,\nтрансформация и передача\nв Elasticsearch.")

    Container(elasticsearch, "Elasticsearch", "v7.17.28", "Хранение и индексация\nлогов приложения.")

    Container(kibana, "Kibana", "v7.17.28", "Визуализация и поиск\nпо логам. Централизованное\nлогирование.")
}

Rel(batch_app, postgres, "JDBC\n(read/write)", "JDBC")
Rel(prometheus, batch_app, "Scrape метрик\n/actuator/prometheus", "HTTP pull, 5s")
Rel(grafana, prometheus, "Запрос метрик", "PromQL")
Rel(filebeat, batch_app, "Сбор логов\nDocker stdout", "Docker API")
Rel(filebeat, logstash, "Отправка логов", "Beats protocol, 5044")
Rel(logstash, elasticsearch, "Индексация логов", "HTTP, 9200")
Rel(kibana, elasticsearch, "Поиск и визуализация", "HTTP, 9200")
Rel(devops, grafana, "Просмотр дашбордов\nи оповещений", "HTTPS, 3000")
Rel(devops, kibana, "Анализ логов", "HTTPS, 5601")

@enduml
